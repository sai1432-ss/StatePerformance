# ==============================================================================
# State Management Benchmark Workbench - Environment Variables Template
# ==============================================================================

# Node runtime environment configuration
NODE_ENV=development

# Application build configuration ports
PORT=5173
VITE_PORT=5173
DOCKER_EXPOSE_PORT=8080

# Base API endpoint configuration (Placeholder for analytics tracking metrics)
VITE_API_URL=https://api.example.com/v1

# Benchmark Feature Flags
VITE_ENABLE_STRICT_MODE=true
VITE_TRACK_PERFORMANCE_METRICS=true